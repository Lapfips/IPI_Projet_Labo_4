# Guacamole Configuration
# Generated by Ansible

# PostgreSQL properties
postgresql-hostname: {{ BASTION_DB_HOST }}
postgresql-port: {{ BASTION_DB_PORT }}
postgresql-database: {{ BASTION_DB_NAME }}
postgresql-username: {{ BASTION_DB_USER }}
postgresql-password: {{ BASTION_DB_PASSWORD }}

# Additional settings
postgresql-auto-create-accounts: true
postgresql-default-max-connections: 3
postgresql-default-max-group-connections: 3
